<controls:ToolWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MacExplorer.Controls"
        xmlns:icons="using:MacExplorer.Assets"
        x:Class="MacExplorer.Views.Dialogs.TaskPanel"
        Title="后台任务" Width="420" Height="480" MinWidth="380" MinHeight="360"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlassMenuBg}">

    <controls:ToolWindow.Styles>
        <!-- ── Stat card ── -->
        <Style Selector="Border.task-summary">
            <Setter Property="Background" Value="{DynamicResource ColorBgHover}"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="12,8"/>
        </Style>
        <Style Selector="TextBlock.task-stat-value">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.task-stat-label">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>

        <!-- ── Task row ── -->
        <Style Selector="Border.task-row">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="CornerRadius" Value="7"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Border.task-row:pointerover">
            <Setter Property="Background" Value="{DynamicResource ColorBgHover}"/>
        </Style>

        <!-- ── Typography ── -->
        <Style Selector="TextBlock.task-title">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>
        <Style Selector="TextBlock.task-meta">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="TextBlock.task-progress-text">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="TextBlock.task-state-pill">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="Medium"/>
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
        </Style>

        <!-- ── State dot ── -->
        <Style Selector="Border.task-dot">
            <Setter Property="Width" Value="8"/>
            <Setter Property="Height" Value="8"/>
            <Setter Property="CornerRadius" Value="999"/>
            <Setter Property="VerticalAlignment" Value="Top"/>
            <Setter Property="Margin" Value="0,5,0,0"/>
        </Style>
        <Style Selector="Border.task-dot.running">
            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        </Style>
        <Style Selector="Border.task-dot.completed">
            <Setter Property="Background" Value="{DynamicResource SuccessBrush}"/>
        </Style>
        <Style Selector="Border.task-dot.failed">
            <Setter Property="Background" Value="{DynamicResource DangerBrush}"/>
        </Style>

        <!-- ── Close button ── -->
        <Style Selector="Button.task-icon-button">
            <Setter Property="MinWidth" Value="24"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CornerRadius" Value="6"/>
        </Style>
        <Style Selector="Button.task-icon-button PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}"/>
        </Style>
        <Style Selector="Button.task-icon-button:pointerover PathIcon">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <!-- ── Progress bar ── -->
        <Style Selector="ProgressBar.task-progress">
            <Setter Property="Height" Value="3"/>
            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Background" Value="{DynamicResource SurfaceMutedBrush}"/>
        </Style>
    </controls:ToolWindow.Styles>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Margin="16" RowSpacing="10">
        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock x:Name="TaskSummaryText" Text="没有正在运行的任务"
                           FontSize="12" Foreground="{DynamicResource TextMutedBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="ClearAllButton" Grid.Column="1"
                    Content="全部清空" Classes="ghost compact"
                    Click="ClearAllTasks"/>
        </Grid>

        <!-- Stat pills -->
        <Grid Grid.Row="1" ColumnDefinitions="*,*,*" ColumnSpacing="6">
            <Border Grid.Column="0" Classes="task-summary">
                <StackPanel Spacing="1">
                    <TextBlock x:Name="RunningCountText" Text="0" Classes="task-stat-value"/>
                    <TextBlock Text="进行中" Classes="task-stat-label"/>
                </StackPanel>
            </Border>
            <Border Grid.Column="1" Classes="task-summary">
                <StackPanel Spacing="1">
                    <TextBlock x:Name="CompletedCountText" Text="0" Classes="task-stat-value"/>
                    <TextBlock Text="已完成" Classes="task-stat-label"/>
                </StackPanel>
            </Border>
            <Border x:Name="FailedStat" Grid.Column="2" Classes="task-summary">
                <StackPanel Spacing="1">
                    <TextBlock x:Name="FailedCountText" Text="0" Classes="task-stat-value"/>
                    <TextBlock Text="需要处理" Classes="task-stat-label"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Task list -->
        <Grid Grid.Row="2">
            <Border x:Name="EmptyPlaceholder"
                    Background="Transparent"
                    Padding="24">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
                    <PathIcon Data="{x:Static icons:Icons.Info}" Width="34" Height="34"
                              Foreground="{DynamicResource TextMutedBrush}"
                              HorizontalAlignment="Center"/>
                    <TextBlock Text="没有后台任务" FontSize="14" FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="所有任务都已处理完毕"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               Foreground="{DynamicResource TextMutedBrush}"/>
                </StackPanel>
            </Border>

            <ScrollViewer x:Name="TaskListScroll"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="3" x:Name="TaskItemsPanel"/>
            </ScrollViewer>
        </Grid>

        <!-- Footer -->
        <Grid Grid.Row="3" ColumnDefinitions="*,Auto" VerticalAlignment="Center">
            <Button x:Name="ClearCompletedButton"
                    Grid.Column="1"
                    Content="清除已完成"
                    Classes="ghost compact"
                    Click="ClearCompleted"/>
        </Grid>
    </Grid>
</controls:ToolWindow>
