<controls:DialogWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:MacExplorer.Controls"
        xmlns:icons="clr-namespace:MacExplorer.Assets"
        x:Class="MacExplorer.Views.Dialogs.PasswordDialog"
        Title="需要密码"
        Width="420"
        MinHeight="260"
        SizeToContent="Height"
        CanResize="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource GlassEffectBg}">

    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="20" Margin="24">
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" ColumnSpacing="12">
            <Border Width="40" Height="40" CornerRadius="10"
                    Background="{DynamicResource ColorBgHover}"
                    VerticalAlignment="Top">
                <PathIcon Data="{x:Static icons:Icons.PasswordHidden}"
                          Width="20" Height="20"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Foreground="{DynamicResource ColorTextPrimary}"/>
            </Border>
            <StackPanel Grid.Column="1" Spacing="4">
                <TextBlock x:Name="DialogTitle"
                           Text="输入压缩包密码"
                           FontSize="17"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource ColorTextPrimary}"/>
                <TextBlock Text="此压缩包已加密，需要密码才能继续打开。"
                           FontSize="13"
                           LineHeight="18"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource ColorTextSecondary}"/>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="1" Spacing="8">
            <TextBlock Text="密码"
                       FontSize="12"
                       FontWeight="Medium"
                       Foreground="{DynamicResource ColorTextSecondary}"/>
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                <TextBox x:Name="PasswordBox" Grid.Column="0"
                         Height="38"
                         PasswordChar="●"
                         PlaceholderText="输入密码"
                         VerticalContentAlignment="Center"/>
                <Button Grid.Column="1" x:Name="ToggleVisibilityBtn"
                        Width="38" Height="38"
                        Classes="secondary"
                        VerticalAlignment="Center"
                        Click="TogglePasswordVisibility">
                    <PathIcon Data="{x:Static icons:Icons.Eye}" Width="16" Height="16"/>
                </Button>
            </Grid>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Spacing="8">
            <Button Content="取消" Width="80" Classes="secondary"
                    IsCancel="True"
                    Click="CancelClick"/>
            <Button Content="确认" Width="80" Classes="primary"
                    IsDefault="True"
                    Click="ConfirmClick"/>
        </StackPanel>
    </Grid>
</controls:DialogWindow>
