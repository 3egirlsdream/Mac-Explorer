<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MacExplorer.ViewModels"
             xmlns:icons="using:MacExplorer.Assets"
             xmlns:models="using:MacExplorer.Models"
             x:Class="MacExplorer.Views.BreadcrumbBar"
             x:DataType="vm:FileListViewModel"
             x:CompileBindings="False">

    <Border Classes="breadcrumb-bar" Padding="4,2" Background="{DynamicResource SurfaceElevatedBrush}">
        <Grid ColumnDefinitions="*">
            <!-- Home Page Mode -->
            <TextBox Grid.Column="0"
                     x:Name="HomePathInput"
                     Classes="breadcrumb-input omnibox-input"
                     PlaceholderText="输入路径、URL 或搜索内容..."
                     IsVisible="{Binding IsHomePage}"
                     GotFocus="OnInputGotFocus"
                     KeyDown="OnInputKeyDown"
                     TextChanged="OnInputTextChanged"
                     LostFocus="OnInputLostFocus"/>

            <!-- Browse Mode: BreadcrumbBar -->
            <ScrollViewer Grid.Column="1"
                          x:Name="BrowseModePanel"
                          IsVisible="{Binding IsHomePage, Converter={StaticResource BoolNotConverter}}"
                          DoubleTapped="OnBrowseModeDoubleTapped"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Breadcrumbs}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="0"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="models:BreadcrumbSegment">
                            <StackPanel Orientation="Horizontal" Spacing="0" Cursor="Hand"
                                        Background="Transparent">
                                <!-- Chevron separator (not shown for first item) -->
                                <PathIcon Data="{x:Static icons:Icons.ChevronRight}"
                                          Width="12" Height="12"
                                          Foreground="{DynamicResource ColorTextQuaternary}"
                                          Margin="2,0"
                                          VerticalAlignment="Center"/>
                                <!-- Segment button -->
                                <Border x:Name="SegmentBorder"
                                        CornerRadius="4"
                                        Padding="6,2"
                                        Background="Transparent"
                                        PointerPressed="OnSegmentClicked"
                                        Tag="{Binding FullPath}">
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontSize="12"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource ColorTextPrimary}"/>
                                </Border>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBox Grid.Column="0"
                     x:Name="PathInput"
                     Classes="breadcrumb-input omnibox-input"
                     PlaceholderText="输入路径、URL 或搜索内容..."
                     IsVisible="False"
                     GotFocus="OnInputGotFocus"
                     KeyDown="OnInputKeyDown"
                     TextChanged="OnInputTextChanged"
                     LostFocus="OnInputLostFocus"/>

            <Popup x:Name="PathSuggestionsPopup"
                   Placement="Bottom"
                   IsLightDismissEnabled="False">
                <Border x:Name="PathSuggestionsSurface"
                        MaxHeight="340"
                        Classes="omnibox-popup">
                    <ListBox x:Name="PathSuggestionList"
                             Classes="omnibox-suggestions">
                        <ListBox.ItemTemplate>
                            <DataTemplate x:DataType="models:OmniboxSuggestion">
                                <Grid ColumnDefinitions="32,*"
                                      Background="Transparent"
                                      Tapped="OnSuggestionTapped">
                                    <Border Width="28" Height="28" CornerRadius="6"
                                            Background="{DynamicResource ColorBgHover}">
                                        <PathIcon Data="{Binding IconData}"
                                                  Width="15" Height="15"
                                                  Foreground="{Binding IconColor}"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="8,0,4,0"
                                                VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{Binding Title}" FontSize="13"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding Subtitle}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>
