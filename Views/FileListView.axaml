<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:MacExplorer.ViewModels"
             xmlns:icons="using:MacExplorer.Assets"
             xmlns:models="using:MacExplorer.Models"
             xmlns:converters="using:MacExplorer.Converters"
             xmlns:local="using:MacExplorer.Views"
             x:Class="MacExplorer.Views.FileListView"
             x:DataType="vm:FileListViewModel"
             x:CompileBindings="False"
             Focusable="True"
             KeyDown="OnFileListKeyDown">

    <UserControl.Resources>
        <converters:FileEntryToIconConverter x:Key="FileIconConverter"/>
        <local:CutOpacityConverter x:Key="CutOpacityConverter"/>
        <ControlTheme x:Key="PresentationRowItemTheme" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Focusable" Value="False"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      HorizontalContentAlignment="Stretch"
                                      VerticalContentAlignment="Stretch"/>
                </ControlTemplate>
            </Setter>
            <!-- Presentation rows only carry group headers or virtualized file rows.
                 They must never expose ListBox hover/selection/focus visuals. -->
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
            <Style Selector="^:focus-visible">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="FileListItemTheme" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter Background="{TemplateBinding Background}"
                                      BorderBrush="{TemplateBinding BorderBrush}"
                                      BorderThickness="{TemplateBinding BorderThickness}"
                                      Content="{TemplateBinding Content}"
                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                      CornerRadius="{TemplateBinding CornerRadius}"
                                      HorizontalContentAlignment="Stretch"
                                      Padding="{TemplateBinding Padding}"/>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ColorBgHover}"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource ColorBgSelected}"/>
            </Style>
            <Style Selector="^:selected:pointerover">
                <Setter Property="Background" Value="{DynamicResource ColorBgSelectedHover}"/>
            </Style>
            <Style Selector="^:focus-visible">
                <Setter Property="BorderBrush" Value="{DynamicResource ColorAccent}"/>
            </Style>
        </ControlTheme>

        <ControlTheme x:Key="FileGridItemTheme" TargetType="ListBoxItem">
            <Setter Property="Width" Value="108"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="Margin" Value="1"/>
            <Setter Property="CornerRadius" Value="0"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ClipToBounds" Value="True"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            ClipToBounds="True">
                        <ContentPresenter
                            Content="{TemplateBinding Content}"
                            ContentTemplate="{TemplateBinding ContentTemplate}"
                            HorizontalContentAlignment="Left"
                            Padding="{TemplateBinding Padding}"/>
                    </Border>
                </ControlTemplate>
            </Setter>
            <Style Selector="^:pointerover">
                <Setter Property="Background" Value="{DynamicResource ColorBgHover}"/>
            </Style>
            <Style Selector="^:selected">
                <Setter Property="Background" Value="{DynamicResource ColorBgSelected}"/>
            </Style>
            <Style Selector="^:selected:pointerover">
                <Setter Property="Background" Value="{DynamicResource ColorBgSelectedHover}"/>
            </Style>
            <Style Selector="^:focus-visible">
                <Setter Property="BorderBrush" Value="{DynamicResource ColorAccent}"/>
            </Style>
        </ControlTheme>

        <DataTemplate x:Key="ListEntryTemplate" x:DataType="models:FileSystemEntry">
            <Border Classes="file-list-entry entry-content" CornerRadius="4" Padding="12,3"
                    Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}"
                    PointerPressed="OnListItemPointerPressed"
                    PointerMoved="OnItemPointerMoved"
                    PointerReleased="OnItemPointerReleased"
                    DoubleTapped="OnFileItemDoubleTapped">
                <Grid Classes="file-list-row-grid" ColumnDefinitions="Auto,*,160,100,80">
                    <Grid Grid.Column="0" Width="22" Height="22" VerticalAlignment="Center">
                        <Image Classes="entry-icon-image"
                               Source="{Binding ., Converter={StaticResource FileIconConverter}, ConverterParameter=24}"
                               Loaded="OnEntryImageLoaded" DataContextChanged="OnEntryImageDataContextChanged"
                               Width="18" Height="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Stretch="Uniform" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        <Border Classes="git-badge" Width="10" Height="10" CornerRadius="5"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                BorderBrush="White" BorderThickness="1" IsVisible="{Binding HasGitBadge}"
                                Background="{Binding GitBadgeColor}">
                            <TextBlock Text="{Binding GitBadgeText}" FontSize="6" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="EntryNameText" Classes="entry-name-text" Grid.Column="1" Text="{Binding DisplayName}"
                               VerticalAlignment="Center" Margin="8,0,0,0" FontSize="13"
                               TextTrimming="CharacterEllipsis"/>
                    <TextBlock Grid.Column="2"
                               Text="{Binding LastModified, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource ColorTextSecondary}"/>
                    <TextBlock Grid.Column="3" Text="{Binding FormattedSize}"
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{DynamicResource ColorTextSecondary}"/>
                    <TextBlock Grid.Column="4" Text="{Binding KindText}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{DynamicResource ColorTextTertiary}"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GridEntryTemplate" x:DataType="models:FileSystemEntry">
            <Border Classes="file-grid-content entry-content" Width="100" Margin="4"
                    Opacity="{Binding IsCut, Converter={StaticResource CutOpacityConverter}}"
                    PointerPressed="OnGridItemPointerPressed"
                    PointerMoved="OnItemPointerMoved"
                    PointerReleased="OnItemPointerReleased"
                    DoubleTapped="OnFileItemDoubleTapped">
                <StackPanel HorizontalAlignment="Center" Width="84">
                    <Grid Width="64" Height="64" HorizontalAlignment="Center">
                        <Image Classes="entry-icon-image"
                               Source="{Binding ., Converter={StaticResource FileIconConverter}, ConverterParameter=256}"
                               Loaded="OnEntryImageLoaded" DataContextChanged="OnEntryImageDataContextChanged"
                               Width="56" Height="56" HorizontalAlignment="Center" VerticalAlignment="Center"
                               Stretch="Uniform" RenderOptions.BitmapInterpolationMode="HighQuality"/>
                        <Border Classes="git-badge" Width="16" Height="16" CornerRadius="8"
                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                BorderBrush="White" BorderThickness="1.5" IsVisible="{Binding HasGitBadge}"
                                Background="{Binding GitBadgeColor}">
                            <TextBlock Text="{Binding GitBadgeText}" FontSize="9" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </Grid>
                    <TextBlock x:Name="EntryNameText" Classes="entry-name-text" Text="{Binding DisplayName}"
                               TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                               FontSize="11" HorizontalAlignment="Center" Margin="0,6,0,0"
                               Foreground="{DynamicResource ColorTextPrimary}"/>
                    <TextBlock Text="{Binding VirtualCountText}" IsVisible="{Binding IsVirtual}"
                               FontSize="10" HorizontalAlignment="Center" Margin="0,2,0,0"
                               Foreground="{DynamicResource ColorTextTertiary}"/>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="GroupedListRowTemplate" x:DataType="local:FileListPresentationRow">
            <Grid Background="{DynamicResource ColorBgContent}">
                <Border IsVisible="{Binding IsGroupHeader}"
                        Background="{DynamicResource ColorBgContent}">
                    <TextBlock Text="{Binding GroupName}" Classes="file-group-header"/>
                </Border>
                <ListBox Classes="file-list grouped-file-list-row"
                         Background="{DynamicResource ColorBgContent}"
                         ItemsSource="{Binding Entries}" IsVisible="{Binding HasEntries}"
                         ItemTemplate="{StaticResource ListEntryTemplate}"
                         ItemContainerTheme="{StaticResource FileListItemTheme}"
                         SelectionMode="Multiple"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled"/>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="GridRowTemplate" x:DataType="local:FileGridPresentationRow">
            <Grid Background="{DynamicResource ColorBgContent}">
                <Border IsVisible="{Binding IsGroupHeader}"
                        Background="{DynamicResource ColorBgContent}">
                    <TextBlock Text="{Binding GroupName}" Classes="file-group-header"/>
                </Border>
                <ListBox Classes="file-grid file-grid-row"
                         Background="{DynamicResource ColorBgContent}"
                         ItemsSource="{Binding Entries}" IsVisible="{Binding HasEntries}"
                         ItemTemplate="{StaticResource GridEntryTemplate}"
                         ItemContainerTheme="{StaticResource FileGridItemTheme}"
                         SelectionMode="Multiple"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Disabled">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>
            </Grid>
        </DataTemplate>
    </UserControl.Resources>

    <UserControl.Styles>
        <!-- Draw interaction states on the visible content layer so hover and selection
             remain stable even when the container theme changes. -->
        <Style Selector="Border.file-list-entry">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
        <Style Selector="Border.file-list-entry:pointerover">
            <Setter Property="Background" Value="{DynamicResource ColorBgHover}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.file-list-entry">
            <Setter Property="Background" Value="{DynamicResource ColorBgSelected}"/>
        </Style>
        <Style Selector="ListBoxItem:selected Border.file-list-entry:pointerover">
            <Setter Property="Background" Value="{DynamicResource ColorBgSelectedHover}"/>
        </Style>

        <Style Selector="Border.entry-content.drag-over">
            <Setter Property="Background" Value="{DynamicResource ColorAccentLight}"/>
        </Style>
    </UserControl.Styles>

    <Grid RowDefinitions="Auto,*" x:Name="InteractionSurface" Background="{DynamicResource ColorBgContent}"
          DragDrop.AllowDrop="True" DragDrop.DragOver="OnDragOver"
          DragDrop.DragLeave="OnDragLeave" DragDrop.Drop="OnDrop">
        <Border Grid.Row="0" Classes="file-list-header" x:Name="ListHeaderPanel"
                Background="{DynamicResource ColorBgContent}"
                BorderBrush="{DynamicResource ColorDivider}"
                BorderThickness="0,0,0,1"
                CornerRadius="4,4,0,0" Margin="0">
            <Grid x:Name="ListHeaderGrid" ColumnDefinitions="Auto,*,160,100,80">
                <TextBlock Grid.Column="1" x:Name="NameHeader" Text="名称" Classes="file-column-header"
                           Margin="38,0,0,0" PointerPressed="OnSortByName"/>
                <TextBlock Grid.Column="2" x:Name="ModifiedHeader" Text="修改日期" Classes="file-column-header"
                           PointerPressed="OnSortByModified"/>
                <TextBlock Grid.Column="3" x:Name="SizeHeader" Text="大小" Classes="file-column-header"
                           PointerPressed="OnSortBySize"/>
                <TextBlock Grid.Column="4" x:Name="TypeHeader" Text="类型" Classes="file-column-header"
                           PointerPressed="OnSortByType"/>
                <Border Grid.Column="2" Tag="2" Width="8" HorizontalAlignment="Left"
                        Background="Transparent" Cursor="SizeWestEast"
                        PointerPressed="OnColumnResizePressed"
                        PointerMoved="OnColumnResizeMoved"
                        PointerReleased="OnColumnResizeReleased"/>
                <Border Grid.Column="3" Tag="3" Width="8" HorizontalAlignment="Left"
                        Background="Transparent" Cursor="SizeWestEast"
                        PointerPressed="OnColumnResizePressed"
                        PointerMoved="OnColumnResizeMoved"
                        PointerReleased="OnColumnResizeReleased"/>
                <Border Grid.Column="4" Tag="4" Width="8" HorizontalAlignment="Left"
                        Background="Transparent" Cursor="SizeWestEast"
                        PointerPressed="OnColumnResizePressed"
                        PointerMoved="OnColumnResizeMoved"
                        PointerReleased="OnColumnResizeReleased"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" x:Name="FileScroll" Background="{DynamicResource ColorBgContent}"
              PointerPressed="OnEmptyAreaPressed">
                <StackPanel x:Name="EmptyState" IsVisible="False"
                            HorizontalAlignment="Center" VerticalAlignment="Center"
                            Margin="0,80,0,0">
                    <PathIcon Data="{x:Static icons:Icons.Folder}" Width="48" Height="48"
                              Foreground="{DynamicResource ColorTextQuaternary}"
                              Opacity="0.3" HorizontalAlignment="Center"/>
                    <TextBlock Classes="empty-state-text" x:Name="EmptyStateText" Text="此文件夹为空"/>
                </StackPanel>

                <ListBox x:Name="FileItemsList" Classes="file-list file-scroll-host"
                         Background="{DynamicResource ColorBgContent}"
                         ItemsSource="{Binding Entries}" ItemTemplate="{StaticResource ListEntryTemplate}"
                         ItemContainerTheme="{StaticResource FileListItemTheme}"
                         SelectionMode="Multiple" SelectionChanged="OnControlSelectionChanged"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel CacheLength="1"/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <ListBox x:Name="GroupedListItems" Classes="presentation-rows Void file-scroll-host" IsVisible="False"
                         Background="{DynamicResource ColorBgContent}"
                         SelectionMode="Single" ItemContainerTheme="{StaticResource PresentationRowItemTheme}"
                         SelectionChanged="OnPresentationRowSelectionChanged"
                         ItemTemplate="{StaticResource GroupedListRowTemplate}">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel CacheLength="1"/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <ListBox x:Name="GridViewItems" Classes="presentation-rows Void file-scroll-host" IsVisible="False"
                         Background="{DynamicResource ColorBgContent}"
                         ItemTemplate="{StaticResource GridRowTemplate}" SelectionMode="Single"
                         ItemContainerTheme="{StaticResource PresentationRowItemTheme}"
                         SelectionChanged="OnPresentationRowSelectionChanged">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate><VirtualizingStackPanel CacheLength="1"/></ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                </ListBox>

                <ListBox x:Name="GroupedGridItems" IsVisible="False"
                         Background="{DynamicResource ColorBgContent}"/>

                <Border IsVisible="{Binding IsLoading}"
                        Background="{DynamicResource GlassContentBg}"
                        IsHitTestVisible="False">
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Width="180" Spacing="8">
                        <ProgressBar IsIndeterminate="True" Height="3"/>
                        <TextBlock Text="正在加载..."
                                   FontSize="12"
                                   TextAlignment="Center"
                                   Foreground="{DynamicResource ColorTextSecondary}"/>
                    </StackPanel>
                </Border>
        </Grid>
    </Grid>
</UserControl>
