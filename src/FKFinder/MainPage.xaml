<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:FKFinder"
             xmlns:components="clr-namespace:FKFinder.Components"
             x:Class="FKFinder.MainPage"
             BackgroundColor="Transparent">  <!-- 保持窗口透明 -->

    <Grid>
        <!-- BlazorWebView -->
        <BlazorWebView x:Name="blazorWebView" 
                       HostPage="wwwroot/index.html" 
                       Background="Transparent"
                       HorizontalOptions="Fill"
                       VerticalOptions="Fill">
            <BlazorWebView.RootComponents>
                <RootComponent Selector="#app" ComponentType="{x:Type components:Routes}" />
            </BlazorWebView.RootComponents>
        </BlazorWebView>
    </Grid>
</ContentPage>