@using FKFinder.Models

@if (Metadata != null)
{
    <div class="metadata-panel glass-effect-without-border">
        <button class="metadata-close-btn" @onclick="Close" title="关闭">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="@Icons.Close"/>
            </svg>
        </button>

        <div class="metadata-header">
            <span class="metadata-icon">@((MarkupString)GetMetadataIcon())</span>
            <div class="metadata-title">
                <div class="metadata-name">@Metadata.Name</div>
                <div class="metadata-kind">@Metadata.Kind</div>
            </div>
        </div>

        <div class="metadata-section">
            <div class="metadata-row">
                <span class="metadata-label">大小</span>
                <span class="metadata-value">@Metadata.FormattedSize</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">位置</span>
                <span class="metadata-value metadata-path" title="@Metadata.FullPath">@GetParentPath()</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">创建时间</span>
                <span class="metadata-value">@Metadata.Created.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">修改时间</span>
                <span class="metadata-value">@Metadata.LastModified.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">访问时间</span>
                <span class="metadata-value">@Metadata.LastAccessed.ToString("yyyy-MM-dd HH:mm:ss")</span>
            </div>
        </div>

        <div class="metadata-section">
            <div class="metadata-row">
                <span class="metadata-label">类型</span>
                <span class="metadata-value">@(string.IsNullOrEmpty(Metadata.ContentType) ? "--" : Metadata.ContentType)</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">所有者</span>
                <span class="metadata-value">@Metadata.Owner</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">群组</span>
                <span class="metadata-value">@Metadata.Group</span>
            </div>
            <div class="metadata-row">
                <span class="metadata-label">权限</span>
                <span class="metadata-value">@Metadata.Permissions</span>
            </div>
        </div>

        @if (Metadata.Tags.Count > 0)
        {
            <div class="metadata-section">
                <div class="metadata-row">
                    <span class="metadata-label">标签</span>
                    <span class="metadata-value">
                        @foreach (var tag in Metadata.Tags)
                        {
                            <span class="metadata-tag">@tag</span>
                        }
                    </span>
                </div>
            </div>
        }

        @if (Metadata.ExtendedAttributes.Count > 0)
        {
            <div class="metadata-section">
                <div class="metadata-label" style="margin-bottom: 4px;">扩展属性</div>
                @foreach (var attr in Metadata.ExtendedAttributes.Take(5))
                {
                    <div class="metadata-xattr">@attr</div>
                }
                @if (Metadata.ExtendedAttributes.Count > 5)
                {
                    <div class="metadata-xattr">...还有 @(Metadata.ExtendedAttributes.Count - 5) 个</div>
                }
            </div>
        }

        @if (Metadata.ImageInfo != null)
        {
            var img = Metadata.ImageInfo;

            @if (img.PixelWidth > 0 || img.PixelHeight > 0 || !string.IsNullOrEmpty(img.ColorSpace) || !string.IsNullOrEmpty(img.ProfileName))
            {
                <div class="metadata-section">
                    <div class="metadata-section-title">图像信息</div>
                    @if (img.PixelWidth > 0 && img.PixelHeight > 0)
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">尺寸</span>
                            <span class="metadata-value">@(img.PixelWidth) x @(img.PixelHeight)</span>
                        </div>
                    }
                    @if (img.DpiWidth > 0)
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">DPI</span>
                            <span class="metadata-value">@(img.DpiWidth) x @(img.DpiHeight)</span>
                        </div>
                    }
                    @if (img.BitsPerSample > 0)
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">位深度</span>
                            <span class="metadata-value">@(img.BitsPerSample) bit</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.ColorSpace))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">色彩空间</span>
                            <span class="metadata-value">@img.ColorSpace</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.ProfileName))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">色彩配置</span>
                            <span class="metadata-value">@img.ProfileName</span>
                        </div>
                    }
                    @if (img.HasAlpha)
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">Alpha 通道</span>
                            <span class="metadata-value">是</span>
                        </div>
                    }
                </div>
            }

            @if (!string.IsNullOrEmpty(img.CameraMake) || !string.IsNullOrEmpty(img.CameraModel) || !string.IsNullOrEmpty(img.LensModel))
            {
                <div class="metadata-section">
                    <div class="metadata-section-title">拍摄信息</div>
                    @if (!string.IsNullOrEmpty(img.CameraMake))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">制造商</span>
                            <span class="metadata-value">@img.CameraMake</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.CameraModel))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">相机型号</span>
                            <span class="metadata-value">@img.CameraModel</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.LensModel))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">镜头</span>
                            <span class="metadata-value">@img.LensModel</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.FocalLength))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">焦距</span>
                            <span class="metadata-value">@img.FocalLength</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.Aperture))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">光圈</span>
                            <span class="metadata-value">@img.Aperture</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.ExposureTime))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">快门速度</span>
                            <span class="metadata-value">@img.ExposureTime</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.IsoSpeed))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">ISO</span>
                            <span class="metadata-value">@img.IsoSpeed</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.WhiteBalance))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">白平衡</span>
                            <span class="metadata-value">@img.WhiteBalance</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.Flash))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">闪光灯</span>
                            <span class="metadata-value">@img.Flash</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.ExposureProgram))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">曝光程序</span>
                            <span class="metadata-value">@img.ExposureProgram</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.MeteringMode))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">测光模式</span>
                            <span class="metadata-value">@img.MeteringMode</span>
                        </div>
                    }
                </div>
            }

            @if (img.Latitude != 0 || img.Longitude != 0 || !string.IsNullOrEmpty(img.Altitude))
            {
                <div class="metadata-section">
                    <div class="metadata-section-title">位置信息</div>
                    @if (img.Latitude != 0 && img.Longitude != 0)
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">纬度</span>
                            <span class="metadata-value">@img.Latitude.ToString("F6")</span>
                        </div>
                        <div class="metadata-row">
                            <span class="metadata-label">经度</span>
                            <span class="metadata-value">@img.Longitude.ToString("F6")</span>
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(img.Altitude))
                    {
                        <div class="metadata-row">
                            <span class="metadata-label">海拔</span>
                            <span class="metadata-value">@img.Altitude</span>
                        </div>
                    }
                </div>
            }

            @if (img.AllProperties.Count > 0)
            {
                <div class="metadata-section">
                    <div class="metadata-section-title metadata-all-props-toggle" @onclick="ToggleAllProperties">
                        所有属性 (@img.AllProperties.Count)
                        <svg class="metadata-toggle-arrow @(_showAllProperties ? "expanded" : "")" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                            <path d="@Icons.Forward"/>
                        </svg>
                    </div>
                    @if (_showAllProperties)
                    {
                        @foreach (var prop in img.AllProperties.OrderBy(p => p.Key))
                        {
                            <div class="metadata-prop-item">
                                <span class="metadata-prop-key" title="@prop.Key">@FormatPropertyKey(prop.Key)</span>
                                <span class="metadata-prop-value">@prop.Value</span>
                            </div>
                        }
                    }
                </div>
            }
        }
    </div>
}

@code {
    [Parameter] public FileMetadata? Metadata { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private bool _showAllProperties;

    private string GetParentPath()
    {
        if (Metadata == null) return "";
        var parent = Path.GetDirectoryName(Metadata.FullPath);
        return string.IsNullOrEmpty(parent) ? "/" : parent;
    }

    private string GetMetadataIcon()
    {
        if (Metadata == null) return FileIconRenderer.Render("file-generic", "", 36);

        var kind = Metadata.Kind;
        var ct = Metadata.ContentType;

        // Folder: use simple stroke icon
        if (kind.Contains("文件夹") || kind.Contains("folder") || ct.Contains("folder"))
            return $@"<svg width=""36"" height=""36"" viewBox=""0 0 24 24"" fill=""none"" stroke=""#54A3F7"" stroke-width=""1.5"" stroke-linecap=""round"" stroke-linejoin=""round""><path d=""{Icons.Folder}""/></svg>";

        // Determine icon key from content type / kind
        var ext = Path.GetExtension(Metadata.Name);
        var iconKey = MapToIconKey(kind, ct);
        return FileIconRenderer.Render(iconKey, ext, 36);
    }

    private static string MapToIconKey(string kind, string ct)
    {
        if (kind.Contains("图像") || kind.Contains("image") || ct.Contains("image")) return "file-image";
        if (kind.Contains("影片") || kind.Contains("movie") || kind.Contains("视频") || ct.Contains("video")) return "file-video";
        if (kind.Contains("音频") || kind.Contains("audio") || ct.Contains("audio")) return "file-audio";
        if (kind.Contains("PDF") || ct.Contains("pdf")) return "file-pdf";
        if (ct.Contains("spreadsheet") || ct.Contains("excel")) return "file-excel";
        if (ct.Contains("presentation") || ct.Contains("powerpoint")) return "file-powerpoint";
        if (ct.Contains("word") || ct.Contains("document") || kind.Contains("文档")) return "file-word";
        if (ct.Contains("archive") || ct.Contains("zip") || ct.Contains("compressed")) return "file-archive";
        if (ct.Contains("html")) return "file-web";
        if (ct.Contains("certificate") || ct.Contains("x-x509")) return "file-certificate";
        if (ct.Contains("source-code") || ct.Contains("script")) return "file-code";
        if (ct.Contains("json") || ct.Contains("xml") || ct.Contains("yaml")) return "file-config";
        if (ct.Contains("markdown")) return "file-markdown";
        return "file-generic";
    }

    private static string FormatPropertyKey(string key)
    {
        if (key.StartsWith("kMDItem"))
            return key["kMDItem".Length..];
        return key;
    }

    private void ToggleAllProperties()
    {
        _showAllProperties = !_showAllProperties;
    }

    private async Task Close()
    {
        await OnClose.InvokeAsync();
    }
}
