@page "/"

@using Masa.Blazor
@using FKFinder.Platforms.MacCatalyst.Services
@inject FileListViewModel ViewModel
@inject IJSRuntime JSRuntime
@inject FKFinder.Services.IQuickLookService QuickLookService
@inject FKFinder.Services.IMouseNavigationService MouseNavService
@inject FKFinder.Services.NavigationBridge NavigationBridge
@inject FKFinder.Services.IBackgroundTaskManager TaskManager
@inject FKFinder.Services.IDragDropBridge DragDropBridge
@inject FKFinder.Services.IDirectoryChangeNotifier DirectoryChangeNotifier
@inject FKFinder.Services.IFSEventsWatcher FSEventsWatcher
@implements IAsyncDisposable

<MApp Style="background:transparent">
<CascadingValue Value="ViewModel">
    <div class="finder-layout">
        @if (!ViewModel.IsHomePage)
        {
            <FinderNavBar />
            <FinderToolbar OnOpenSettings="@(() => _settingsDialogVisible = true)" />
        }
        <div class="finder-body">
            <FinderSidebar />
            <div class="finder-content-split">
                <div class="finder-content-main">
                    <div class="loading-indicator @(ViewModel.IsLoading ? "active" : "")"></div>
                    @if (ViewModel.IsHomePage)
                    {
                        <BreadcrumbBar />
                        <HomeView />
                    }
                    else if (ViewModel.IsAiView)
                    {
                        <AiViewHost />
                    }
                    else
                    {
                        <FileGridView />
                    }
                </div>
                @if (ViewModel.IsPreviewPaneVisible && !ViewModel.IsHomePage)
                {
                    <PreviewPane />
                }
            </div>
        </div>
    </div>
</CascadingValue>

@* Native NSMenu replaces Blazor context menu — Blazor fallback preserved below:
@if (ViewModel.IsContextMenuVisible)
{
    <ContextMenu X="ViewModel.ContextMenuX" Y="ViewModel.ContextMenuY"
                 Actions="ViewModel.ContextMenuActions"
                 OnClose="CloseContextMenu" />
}
*@

@if (ViewModel.IsMetadataPanelVisible)
{
    <MetadataPanel Metadata="ViewModel.CurrentMetadata" OnClose="CloseMetadata" />
}

<MDialog @bind-Value="_progressDialogVisible"
         MaxWidth="380"
         ContentClass="fk-dialog-glass-dense"
         HideOverlay="true"
         Persistent="true">
    @if (_activeTask != null)
    {
        <CenterProgressCard Task="_activeTask" OnMinimize="OnMinimizeTask" />
    }
</MDialog>

<MDialog @bind-Value="_compressDialogVisible"
         MaxWidth="380"
         ContentClass="fk-dialog-glass"
         HideOverlay="true"
         Persistent="true">
    @if (ViewModel.PendingCompressOptions != null)
    {
        <CompressDialog Options="ViewModel.PendingCompressOptions"
                        OnConfirm="OnCompressConfirm"
                        OnCancel="OnCompressCancel" />
    }
</MDialog>

<MDialog @bind-Value="_settingsDialogVisible"
         MaxWidth="420"
         ContentClass="fk-dialog-glass"
         HideOverlay="true">
    <SettingsDialog OnClose="@(() => _settingsDialogVisible = false)" />
</MDialog>

<TaskPanel />
</MApp>

@code {
    private DotNetObjectReference<Home>? _dotNetRef;
    private bool _compressDialogVisible;
    private bool _progressDialogVisible;
    private bool _settingsDialogVisible;
    private BackgroundTaskInfo? _activeTask;

    protected override void OnInitialized()
    {
        // Register this window's ViewModel with bridges
        NavigationBridge.Register(ViewModel);
        DragDropBridge.Register(ViewModel);
        DirectoryChangeNotifier.Subscribe(ViewModel);
        // Note: MacDragDropBridge.Register() now also calls RegisterViewModelForCurrentWindow()
        // to establish the NSWindow -> ViewModel mapping for cross-window drag-drop

        // Check if this new window should navigate to a pending folder path
        var pendingPath = NavigationBridge.PendingNavigationPath;
        Console.WriteLine($"[FKFinder] Home.OnInitialized: PendingNavigationPath='{pendingPath}'");

        // Also check the static cold-start fallback from SceneDelegate
#if MACCATALYST
        if (string.IsNullOrEmpty(pendingPath))
        {
            pendingPath = FKFinder.SceneDelegate._coldStartPath;
            Console.WriteLine($"[FKFinder] Home.OnInitialized: _coldStartPath='{pendingPath}'");
            FKFinder.SceneDelegate._coldStartPath = null;
        }
#endif

        if (!string.IsNullOrEmpty(pendingPath))
        {
            Console.WriteLine($"[FKFinder] Home.OnInitialized: navigating to pending path '{pendingPath}'");
            NavigationBridge.PendingNavigationPath = null;
            _ = ViewModel.NavigateToCommand.ExecuteAsync(pendingPath);
        }
        else
        {
            Console.WriteLine("[FKFinder] Home.OnInitialized: no pending path");
        }

        // Subscribe to ViewModel property changes to trigger re-render
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        TaskManager.TasksChanged += OnTasksChanged;

        // Subscribe to mouse side buttons (back/forward)
        MouseNavService.BackButtonPressed += OnMouseBack;
        MouseNavService.ForwardButtonPressed += OnMouseForward;
        MouseNavService.Start();
    }

    private async void OnMouseBack()
    {
        await InvokeAsync(async () => await ViewModel.NavigateBackCommand.ExecuteAsync(null));
    }

    private async void OnMouseForward()
    {
        await InvokeAsync(async () => await ViewModel.NavigateForwardCommand.ExecuteAsync(null));
    }

    private async void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        // Only re-render Home for properties that affect its layout
        if (e.PropertyName is nameof(ViewModel.IsHomePage)
            or nameof(ViewModel.IsLoading)
            or nameof(ViewModel.CurrentPath)
            or nameof(ViewModel.IsPreviewPaneVisible)
            or nameof(ViewModel.IsContextMenuVisible)
            or nameof(ViewModel.IsMetadataPanelVisible)
            or nameof(ViewModel.SortField)
            or nameof(ViewModel.SortAscending)
            or nameof(ViewModel.IsCompressDialogVisible)
            or nameof(ViewModel.ActiveTaskId)
            or nameof(ViewModel.IsArchiveView)
            or nameof(ViewModel.IsAiView)
            or nameof(ViewModel.PinnedFolders))
        {
            SyncDialogState();
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                _dotNetRef = DotNetObjectReference.Create(this);
                await JSRuntime.InvokeVoidAsync("fkfinderKeyboard.init", _dotNetRef);
            }
            catch { }
        }
    }


    [Microsoft.JSInterop.JSInvokable]
    public async Task OnKeyboardShortcut(string action)
    {
        try
        {
            switch (action)
            {
                case "copy":
                    if (ViewModel.IsArchiveView) break;
                    ViewModel.CopySelectedCommand.Execute(null);
                    break;
                case "cut":
                    if (ViewModel.IsArchiveView) break;
                    ViewModel.CutSelectedCommand.Execute(null);
                    break;
                case "paste":
                    if (ViewModel.IsArchiveView) break;
                    await ViewModel.PasteCommand.ExecuteAsync(null);
                    break;
                case "delete":
                    if (ViewModel.IsArchiveView) break;
                    await ViewModel.DeleteSelectedCommand.ExecuteAsync(null);
                    break;
                case "selectAll":
                    ViewModel.SelectAll();
                    await InvokeAsync(StateHasChanged);
                    break;
                case "navigateUp":
                    await ViewModel.NavigateUpCommand.ExecuteAsync(null);
                    break;
                case "navigateBack":
                    await ViewModel.NavigateBackCommand.ExecuteAsync(null);
                    break;
                case "navigateForward":
                    await ViewModel.NavigateForwardCommand.ExecuteAsync(null);
                    break;
                case "refresh":
                    await ViewModel.RefreshCommand.ExecuteAsync(null);
                    break;
                case "showInfo":
                    if (ViewModel.SelectedEntries.Count == 1)
                        await ViewModel.ShowMetadataCommand.ExecuteAsync(ViewModel.SelectedEntries.First());
                    break;
                case "enter":
                    if (ViewModel.SelectedEntries.Count == 1)
                    {
                        if (ViewModel.IsArchiveView)
                            await ViewModel.OpenEntryCommand.ExecuteAsync(ViewModel.SelectedEntries.First());
                        else
                            ViewModel.RequestRename(ViewModel.SelectedEntries.First());
                    }
                    break;
                case "open":
                    if (ViewModel.SelectedEntries.Count == 1)
                        await ViewModel.OpenEntryCommand.ExecuteAsync(ViewModel.SelectedEntries.First());
                    break;
                case "newFolder":
                    if (ViewModel.IsArchiveView) break;
                    await ViewModel.CreateNewFolderCommand.ExecuteAsync(null);
                    break;
                case "newFile":
                    if (ViewModel.IsArchiveView) break;
                    await ViewModel.CreateNewFileCommand.ExecuteAsync(".txt");
                    break;
                case "quickLook":
                    if (ViewModel.SelectedEntries.Count == 1)
                        await QuickLookService.PreviewFileAsync(ViewModel.SelectedEntries.First().FullPath);
                    break;
                case "togglePreview":
                    ViewModel.TogglePreviewPane();
                    break;
            }
        }
        catch { }
    }

    private void CloseMetadata()
    {
        ViewModel.CloseMetadataCommand.Execute(null);
    }

    private void CloseContextMenu()
    {
        ViewModel.CloseContextMenuCommand.Execute(null);
    }

    private void OnCompressConfirm(FKFinder.Models.CompressOptions options)
    {
        ViewModel.ConfirmCompress(options);
    }

    private void OnCompressCancel()
    {
        ViewModel.CancelCompressDialog();
    }

    private void OnMinimizeTask()
    {
        ViewModel.MinimizeActiveTask();
    }

    private async void OnTasksChanged()
    {
        SyncDialogState();
        await InvokeAsync(StateHasChanged);
    }

    private void SyncDialogState()
    {
        _compressDialogVisible = ViewModel.IsCompressDialogVisible
                                 && ViewModel.PendingCompressOptions != null;

        var activeTask = ViewModel.ActiveTaskId != null
            ? TaskManager.Tasks.FirstOrDefault(t => t.Id == ViewModel.ActiveTaskId)
            : null;
        _activeTask = activeTask;
        _progressDialogVisible = activeTask != null;
    }

    public async ValueTask DisposeAsync()
    {
        DirectoryChangeNotifier.Unsubscribe(ViewModel);
        if (!string.IsNullOrEmpty(ViewModel.CurrentPath))
            FSEventsWatcher.UnwatchDirectory(ViewModel.CurrentPath);

        NavigationBridge.Unregister(ViewModel);
        DragDropBridge.Unregister(ViewModel);
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        TaskManager.TasksChanged -= OnTasksChanged;
        MouseNavService.BackButtonPressed -= OnMouseBack;
        MouseNavService.ForwardButtonPressed -= OnMouseForward;
        _dotNetRef?.Dispose();
        await ValueTask.CompletedTask;
    }
}
