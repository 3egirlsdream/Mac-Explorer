@using FKFinder.Models

<div class="center-progress-card">
    <div class="center-progress-header">
        <span class="center-progress-label">@Task.Label</span>
        <button class="center-progress-minimize" @onclick="OnMinimize" title="收起到任务面板">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="7 13 12 18 17 13"/>
                <line x1="12" y1="18" x2="12" y2="6"/>
            </svg>
        </button>
    </div>
    <div class="center-progress-track">
        <div class="center-progress-bar @StateClass" style="width: @($"{Task.Progress:F0}%")"></div>
    </div>
    <div class="center-progress-footer">
        <span class="center-progress-file" title="@Task.CurrentFile">@TruncatedFile</span>
        <span class="center-progress-pct">@($"{Task.Progress:F0}%")</span>
    </div>
    @if (Task.State == BackgroundTaskState.Failed)
    {
        <div class="center-progress-error">@Task.ErrorMessage</div>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public BackgroundTaskInfo Task { get; set; } = default!;

    [Parameter]
    public EventCallback OnMinimize { get; set; }

    private string StateClass => Task.State switch
    {
        BackgroundTaskState.Completed => "completed",
        BackgroundTaskState.Failed => "failed",
        _ => ""
    };

    private string TruncatedFile
    {
        get
        {
            var f = Task.CurrentFile;
            return f.Length > 50 ? "..." + f[^47..] : f;
        }
    }
}
