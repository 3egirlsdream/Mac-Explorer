@using FKFinder.Models
@using FKFinder.Indexing
@using System.IO
@inject FKFinder.Services.NavigationBridge NavigationBridge
@inject IJSRuntime JSRuntime
@inject IFileIndex FileIndex
@inject FKFinder.Services.IAiTagService AiTagService

<div class="breadcrumb-bar @GetCssClass()" @onclick="ActivatePathInput" @onclick:stopPropagation>
    @if (ViewModel.IsHomePage)
    {
        <svg class="breadcrumb-home-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        <input class="breadcrumb-home-input @(_pathError != null ? "breadcrumb-input-error" : "")" type="text"
               placeholder="@(_pathError ?? "输入路径前往...")" 
               value="@_pathInput"
               @oninput="OnPathInputChanged"
               @onkeydown="OnPathInputKeyDown"
               @onkeydown:preventDefault="_preventDefaultKey"
               @onfocus="ClearPathError"
               @onblur="OnInputBlur"
               @ref="_pathInputRef" />
        @if ((_suggestions.Count > 0 || _aiSuggestions.Count > 0) && _showSuggestions)
        {
            <div class="breadcrumb-suggestions">
                @for (int i = 0; i < _suggestions.Count; i++)
                {
                    var index = i;
                    var item = _suggestions[i];
                    <div class="breadcrumb-suggestion-item @(index == _selectedIndex ? "selected" : "")"
                         @onmousedown="() => SelectSuggestion(item)"
                         @onmouseenter="() => _selectedIndex = index">
                        @((MarkupString)GetSuggestionIcon(item))
                        <div class="suggestion-text">
                            <span class="suggestion-name">@item.Name</span>
                            <span class="suggestion-path">@GetParentDisplay(item.FullPath)</span>
                        </div>
                    </div>
                }
                @if (_aiSuggestions.Count > 0)
                {
                    @if (_suggestions.Count > 0)
                    {
                        <div class="breadcrumb-suggestion-divider"></div>
                    }
                    @foreach (var ai in _aiSuggestions)
                    {
                        <div class="breadcrumb-suggestion-item ai-suggestion"
                             @onmousedown="() => SelectAiSuggestion(ai)">
                            <span class="suggestion-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="@GetAiTagColor(ai.TagType)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
                                </svg>
                            </span>
                            <div class="suggestion-text">
                                <span class="suggestion-name">@ai.TagValue</span>
                                <span class="suggestion-path">AI @GetAiTagLabel(ai.TagType) · @ai.FileCount 项</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    }
    else if (_isEditingPath)
    {
        <input class="breadcrumb-input @(_pathError != null ? "breadcrumb-input-error" : "")" type="text"
               placeholder="@(_pathError ?? "")" 
               value="@_pathInput"
               @oninput="OnPathInputChanged"
               @onkeydown="OnPathInputKeyDown"
               @onkeydown:preventDefault="_preventDefaultKey"
               @onblur="OnEditBlur"
               @onfocus="ClearPathError"
               @ref="_pathInputRef" />
        @if ((_suggestions.Count > 0 || _aiSuggestions.Count > 0) && _showSuggestions)
        {
            <div class="breadcrumb-suggestions breadcrumb-suggestions-inline">
                @for (int i = 0; i < _suggestions.Count; i++)
                {
                    var index = i;
                    var item = _suggestions[i];
                    <div class="breadcrumb-suggestion-item @(index == _selectedIndex ? "selected" : "")"
                         @onmousedown="() => SelectSuggestion(item)"
                         @onmouseenter="() => _selectedIndex = index">
                        @((MarkupString)GetSuggestionIcon(item))
                        <div class="suggestion-text">
                            <span class="suggestion-name">@item.Name</span>
                            <span class="suggestion-path">@GetParentDisplay(item.FullPath)</span>
                        </div>
                    </div>
                }
                @if (_aiSuggestions.Count > 0)
                {
                    @if (_suggestions.Count > 0)
                    {
                        <div class="breadcrumb-suggestion-divider"></div>
                    }
                    @foreach (var ai in _aiSuggestions)
                    {
                        <div class="breadcrumb-suggestion-item ai-suggestion"
                             @onmousedown="() => SelectAiSuggestion(ai)">
                            <span class="suggestion-icon">
                                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="@GetAiTagColor(ai.TagType)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/>
                                </svg>
                            </span>
                            <div class="suggestion-text">
                                <span class="suggestion-name">@ai.TagValue</span>
                                <span class="suggestion-path">AI @GetAiTagLabel(ai.TagType) · @ai.FileCount 项</span>
                            </div>
                        </div>
                    }
                }
            </div>
        }
    }
    else
    {
        @if (ViewModel.Breadcrumbs.Count == 0)
        {
            <div class="breadcrumb-segment">
                <span class="breadcrumb-link current">主页</span>
            </div>
        }
        else
        {
            @foreach (var segment in ViewModel.Breadcrumbs)
            {
                <div class="breadcrumb-segment">
                    <span class="breadcrumb-link @(segment == ViewModel.Breadcrumbs.Last() ? "current" : "")"
                          @onclick="() => NavigateTo(segment.FullPath)" @onclick:stopPropagation>
                        @segment.Name
                    </span>
                    @if (segment != ViewModel.Breadcrumbs.Last())
                    {
                        <svg class="breadcrumb-chevron" width="8" height="8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
                    }
                </div>
            }
        }
    }
</div>

@code {
    [CascadingParameter] public FileListViewModel ViewModel { get; set; } = null!;

    private bool _isEditingPath;
    private bool _needsFocus;
    private string _pathInput = "";
    private string? _pathError;
    private ElementReference _pathInputRef;
    private bool _wasHomePage = true;

    // Search suggestions state
    private List<FileSystemEntry> _suggestions = [];
    private List<AiCategory> _aiSuggestions = [];
    private bool _showSuggestions;
    private int _selectedIndex = -1;
    private CancellationTokenSource? _debounceCtx;
    private bool _preventDefaultKey;
    private bool _isSelectingSuggestion;

    private string GetCssClass()
    {
        if (ViewModel.IsHomePage) return "breadcrumb-home";
        return "";
    }

    protected override void OnParametersSet()
    {
        _wasHomePage = ViewModel.IsHomePage;
    }

    private async Task NavigateTo(string path)
    {
        await ViewModel.NavigateToCommand.ExecuteAsync(path);
    }

    private void ActivatePathInput()
    {
        if (ViewModel.IsHomePage) return;
        if (ViewModel.IsCollectionView) return;
        if (ViewModel.IsArchiveView) return;
        if (ViewModel.IsAiView) return;
        if (_isEditingPath) return;
        _isEditingPath = true;
        _needsFocus = true;
        _pathInput = ViewModel.CurrentPath;
    }

    private string GetParentDisplay(string fullPath)
    {
        var parent = Path.GetDirectoryName(fullPath);
        if (string.IsNullOrEmpty(parent)) return "/";
        var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
        if (!string.IsNullOrEmpty(home) && parent.StartsWith(home, StringComparison.Ordinal))
            return "~" + parent[home.Length..];
        return parent;
    }

    private string GetSuggestionIcon(FileSystemEntry entry)
    {
        const int size = 20;
        if (entry.IsDirectory)
            return $"<span class='suggestion-icon'>{FileIconRenderer.RenderFolder(size)}</span>";
        return $"<span class='suggestion-icon'>{FileIconRenderer.Render(entry.IconKey, entry.Extension, size)}</span>";
    }

    private async Task OnPathInputChanged(ChangeEventArgs e)
    {
        _pathInput = e.Value?.ToString() ?? "";
        _debounceCtx?.Cancel();
        _debounceCtx = new CancellationTokenSource();
        var token = _debounceCtx.Token;
        var query = _pathInput;

        if (string.IsNullOrWhiteSpace(query))
        {
            _suggestions.Clear(); _aiSuggestions.Clear();
            _showSuggestions = false;
            _selectedIndex = -1;
            return;
        }

        try
        {
            // Debounce 150ms
            await Task.Delay(150, token);
            if (token.IsCancellationRequested) return;

            var results = new List<FileSystemEntry>();

            // Strategy 1: If input looks like a path (starts with / or ~), list directory contents
            var expandedPath = query;
            if (expandedPath.StartsWith("~"))
            {
                var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
                expandedPath = home + expandedPath[1..];
            }

            if (expandedPath.StartsWith("/"))
            {
                var dirPath = expandedPath;
                var prefix = "";
                // If path doesn't end with /, treat last segment as filter prefix
                if (!expandedPath.EndsWith("/") && expandedPath.Length > 1)
                {
                    dirPath = Path.GetDirectoryName(expandedPath) ?? "/";
                    prefix = Path.GetFileName(expandedPath);
                }

                if (Directory.Exists(dirPath))
                {
                    try
                    {
                        var entries = Directory.GetFileSystemEntries(dirPath)
                            .Where(p => string.IsNullOrEmpty(prefix) ||
                                        Path.GetFileName(p).Contains(prefix, StringComparison.OrdinalIgnoreCase))
                            .Take(8)
                            .Select(p =>
                            {
                                var isDir = Directory.Exists(p);
                                var ext = Path.GetExtension(p);
                                return new FileSystemEntry
                                {
                                    FullPath = p,
                                    Name = Path.GetFileName(p),
                                    IsDirectory = isDir,
                                    Extension = ext,
                                    IconKey = isDir
                                        ? SqliteFileIndex.ResolveBundleIconKey(ext)
                                        : SqliteFileIndex.ResolveIconKey(ext)
                                };
                            })
                            .OrderByDescending(e => e.IsDirectory)
                            .ThenBy(e => e.Name, StringComparer.OrdinalIgnoreCase);
                        results.AddRange(entries);
                    }
                    catch { }
                }
            }

            // Strategy 2: Search by name from file index
            if (results.Count < 8)
            {
                try
                {
                    var indexResults = await FileIndex.SearchByNameAsync(query, 8 - results.Count);
                    // Avoid duplicates
                    var existingPaths = new HashSet<string>(results.Select(r => r.FullPath));
                    foreach (var entry in indexResults)
                    {
                        if (existingPaths.Add(entry.FullPath))
                            results.Add(entry);
                    }
                }
                catch { }
            }

            if (token.IsCancellationRequested) return;

            // Strategy 3: Search AI tag categories
            var aiResults = new List<AiCategory>();
            if (query.Length >= 2 && !query.StartsWith("/") && !query.StartsWith("~"))
            {
                try
                {
                    var cats = await AiTagService.SearchCategoriesAsync(query, 4);
                    aiResults.AddRange(cats);
                }
                catch { }
            }

            if (token.IsCancellationRequested) return;

            _suggestions = results.Take(8).ToList();
            _aiSuggestions = aiResults;
            _showSuggestions = _suggestions.Count > 0 || _aiSuggestions.Count > 0;
            _selectedIndex = -1;
            StateHasChanged();
        }
        catch (TaskCanceledException) { }
    }

    private async Task OnPathInputKeyDown(KeyboardEventArgs e)
    {
        _preventDefaultKey = false;

        if (_showSuggestions && _suggestions.Count > 0)
        {
            if (e.Key == "ArrowDown")
            {
                _preventDefaultKey = true;
                _selectedIndex = (_selectedIndex + 1) % _suggestions.Count;
                return;
            }
            if (e.Key == "ArrowUp")
            {
                _preventDefaultKey = true;
                _selectedIndex = _selectedIndex <= 0 ? _suggestions.Count - 1 : _selectedIndex - 1;
                return;
            }
            if (e.Key == "Enter" && _selectedIndex >= 0 && _selectedIndex < _suggestions.Count)
            {
                _preventDefaultKey = true;
                var selected = _suggestions[_selectedIndex];
                await SelectSuggestion(selected);
                return;
            }
            if (e.Key == "Tab" && _selectedIndex >= 0 && _selectedIndex < _suggestions.Count)
            {
                _preventDefaultKey = true;
                var selected = _suggestions[_selectedIndex];
                // Tab fills the path but doesn't navigate
                _pathInput = selected.IsDirectory ? selected.FullPath + "/" : selected.FullPath;
                _suggestions.Clear();
                _aiSuggestions.Clear();
                _showSuggestions = false;
                _selectedIndex = -1;
                return;
            }
        }

        if (e.Key == "Enter")
        {
            _preventDefaultKey = true;
            _showSuggestions = false;
            _suggestions.Clear();
            _aiSuggestions.Clear();
            await CommitPathInput();
        }
        else if (e.Key == "Escape")
        {
            if (_showSuggestions)
            {
                _showSuggestions = false;
                _suggestions.Clear();
                _aiSuggestions.Clear();
                _selectedIndex = -1;
            }
            else
            {
                _isEditingPath = false;
                _pathInput = "";
            }
        }
    }

    private async Task SelectSuggestion(FileSystemEntry entry)
    {
        _isSelectingSuggestion = true;
        _suggestions.Clear();
        _aiSuggestions.Clear();
        _showSuggestions = false;
        _selectedIndex = -1;
        _pathError = null;
        _pathInput = "";
        _isEditingPath = false;

        if (entry.IsDirectory)
        {
            await ViewModel.NavigateToCommand.ExecuteAsync(entry.FullPath);
        }
        else
        {
            // Navigate to parent directory and select the file
            var parentDir = Path.GetDirectoryName(entry.FullPath);
            if (!string.IsNullOrEmpty(parentDir))
            {
                ViewModel.PendingSelectFileName = entry.Name;
                ViewModel.ScrollBehaviorAfterLoad = FileListViewModel.ScrollMode.ScrollToSelected;
                await ViewModel.NavigateToCommand.ExecuteAsync(parentDir);
            }
        }
        _isSelectingSuggestion = false;
    }

    private async Task CommitPathInput()
    {
        var path = _pathInput.Trim();
        if (path.StartsWith("~"))
        {
            var home = Environment.GetFolderPath(Environment.SpecialFolder.UserProfile);
            path = home + path[1..];
        }
        if (!string.IsNullOrEmpty(path) && !Directory.Exists(path))
        {
            _pathError = $"路径不存在: {path}";
            _pathInput = "";
            _isEditingPath = false;
            return;
        }
        _isEditingPath = false;
        _pathError = null;
        _pathInput = "";
        if (!string.IsNullOrEmpty(path))
        {
            await ViewModel.NavigateToCommand.ExecuteAsync(path);
        }
    }

    private void OnInputBlur()
    {
        if (_isSelectingSuggestion) return;
        // Delay to allow click on suggestion
        _ = Task.Delay(200).ContinueWith(_ => InvokeAsync(() =>
        {
            if (!_isSelectingSuggestion)
            {
                _showSuggestions = false;
                _suggestions.Clear();
                _aiSuggestions.Clear();
                _selectedIndex = -1;
                StateHasChanged();
            }
        }));
    }

    private async Task OnEditBlur()
    {
        if (_isSelectingSuggestion) return;
        // Small delay to allow suggestion click
        await Task.Delay(200);
        if (!_isSelectingSuggestion)
        {
            _showSuggestions = false;
            _suggestions.Clear();
            _aiSuggestions.Clear();
            _selectedIndex = -1;
            await CommitPathInput();
        }
    }

    private void ClearPathError()
    {
        _pathError = null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && ViewModel.IsHomePage && NavigationBridge.PendingQuickAccessFocus)
        {
            NavigationBridge.PendingQuickAccessFocus = false;
            try { await _pathInputRef.FocusAsync(); } catch { }
        }
        else if (_needsFocus)
        {
            _needsFocus = false;
            try
            {
                await _pathInputRef.FocusAsync();
                await JSRuntime.InvokeVoidAsync("eval", "document.activeElement && (document.activeElement.selectionStart = document.activeElement.selectionEnd = document.activeElement.value.length)");
            }
            catch { }
        }
    }

    private async Task SelectAiSuggestion(AiCategory category)
    {
        _isSelectingSuggestion = true;
        _suggestions.Clear();
        _aiSuggestions.Clear();
        _showSuggestions = false;
        _selectedIndex = -1;
        _pathError = null;
        _pathInput = "";
        _isEditingPath = false;

        await ViewModel.NavigateToAiCategoryAsync(category.TagType, category.TagValue);
        _isSelectingSuggestion = false;
    }

    private static string GetAiTagColor(string tagType) => tagType switch
    {
        "scene" => "#3B82F6",
        "object" => "#F59E0B",
        "animal" => "#10B981",
        "location" => "#EF4444",
        "date" => "#8B5CF6",
        "face" => "#EC4899",
        _ => "#6B7280"
    };

    private static string GetAiTagLabel(string tagType) => tagType switch
    {
        "scene" => "场景",
        "object" => "物品",
        "animal" => "动物",
        "location" => "地点",
        "date" => "日期",
        "face" => "人物",
        "text" => "文字",
        "text_summary" => "关键词",
        "camera" => "相机",
        _ => tagType
    };
}
