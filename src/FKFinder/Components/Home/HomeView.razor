@using FKFinder.Models

<div class="home-view">
    <div class="home-section">
        <div class="home-section-title">快速访问</div>
        <div class="home-tiles-grid">
            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#54A3F7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/>
                        <path d="M9 22V12h6v10"/>
                    </svg>
                </div>
                <div class="home-tile-name">主目录</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Desktop"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#54A3F7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="3" width="20" height="14" rx="2"/>
                        <path d="M8 21h8M12 17v4"/>
                    </svg>
                </div>
                <div class="home-tile-name">桌面</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Documents"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#3B82F6" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="@Icons.FileText"/>
                    </svg>
                </div>
                <div class="home-tile-name">文稿</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Downloads"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#22C55E" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
                    </svg>
                </div>
                <div class="home-tile-name">下载</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Pictures"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#E8912D" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2"/>
                        <circle cx="8.5" cy="8.5" r="1.5"/>
                        <path d="M21 15l-5-5L5 21"/>
                    </svg>
                </div>
                <div class="home-tile-name">图片</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Music"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#EC4899" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M9 18V5l12-2v13"/>
                        <circle cx="6" cy="18" r="3"/>
                        <circle cx="18" cy="16" r="3"/>
                    </svg>
                </div>
                <div class="home-tile-name">音乐</div>
            </div>
        </div>
    </div>

    <div class="home-section">
        <div class="home-section-title">位置</div>
        <div class="home-tiles-grid">
            <div class="home-tile" @ondblclick="@(() => NavigateTo("/"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#8B8B8B" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="2" y="2" width="20" height="20" rx="2.18"/>
                        <path d="M7 2v20M17 2v20M2 12h20M2 7h5M2 17h5M17 17h5M17 7h5"/>
                    </svg>
                </div>
                <div class="home-tile-name">Macintosh HD</div>
            </div>

            <div class="home-tile" @ondblclick="@(() => NavigateTo("/Applications"))">
                <div class="home-tile-icon">
                    <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="#6366F1" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="7"/>
                        <rect x="14" y="3" width="7" height="7"/>
                        <rect x="14" y="14" width="7" height="7"/>
                        <rect x="3" y="14" width="7" height="7"/>
                    </svg>
                </div>
                <div class="home-tile-name">应用程序</div>
            </div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public FileListViewModel ViewModel { get; set; } = null!;

    private async Task NavigateTo(string path)
    {
        await ViewModel.NavigateToCommand.ExecuteAsync(path);
    }
}
