@using FKFinder.Models

<div class="home-view">
    <div class="home-fab-container">
        <div class="home-fab-group" @onclick="@(() => NavigateTo(ViewModel.HomeDirectory))">
            <div class="home-fab">
                <div class="home-fab-icon">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <defs>
                            <linearGradient id="grad-home" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#60A5FA"/>
                                <stop offset="100%" stop-color="#3B82F6"/>
                            </linearGradient>
                        </defs>
                        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" stroke="url(#grad-home)" stroke-width="1.6" fill="rgba(59,130,246,0.08)"/>
                        <path d="M9 22V12h6v10" stroke="url(#grad-home)" stroke-width="1.6"/>
                    </svg>
                </div>
            </div>
            <div class="home-fab-label">主目录</div>
        </div>

        <div class="home-fab-group" @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Desktop"))">
            <div class="home-fab">
                <div class="home-fab-icon">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <defs>
                            <linearGradient id="grad-desktop" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#818CF8"/>
                                <stop offset="100%" stop-color="#6366F1"/>
                            </linearGradient>
                        </defs>
                        <rect x="2" y="3" width="20" height="14" rx="2" stroke="url(#grad-desktop)" stroke-width="1.6" fill="rgba(99,102,241,0.08)"/>
                        <path d="M8 21h8M12 17v4" stroke="url(#grad-desktop)" stroke-width="1.6"/>
                    </svg>
                </div>
            </div>
            <div class="home-fab-label">桌面</div>
        </div>

        <div class="home-fab-group" @onclick="@(() => NavigateTo("/"))">
            <div class="home-fab">
                <div class="home-fab-icon">
                    <svg width="52" height="52" viewBox="0 0 24 24" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <defs>
                            <linearGradient id="grad-hd" x1="0%" y1="0%" x2="100%" y2="100%">
                                <stop offset="0%" stop-color="#67E8F9"/>
                                <stop offset="100%" stop-color="#22D3EE"/>
                            </linearGradient>
                        </defs>
                        <rect x="3" y="1" width="18" height="15" rx="2.5" stroke="url(#grad-hd)" stroke-width="1.6" fill="rgba(34,211,238,0.06)"/>
                        <path d="M12 5.5v1.2" stroke="url(#grad-hd)" stroke-width="0.8"/>
                        <path d="M12.2 5.5c.5-.5 1.1-.4 1.4 0" stroke="url(#grad-hd)" stroke-width="0.8"/>
                        <path d="M10.5 6.8C9 7.2 9 9.5 9.5 10.8C10 12 11 11.8 12 11.5C13 11.8 14 12 14.5 10.8C15 9.5 15 7.2 13.5 6.8C13 6.5 12.5 7 12 7.2C11.5 7 11 6.5 10.5 6.8Z" stroke="url(#grad-hd)" stroke-width="0.8"/>
                        <path d="M12 16v3M8 19h8" stroke="url(#grad-hd)" stroke-width="1.6"/>
                    </svg>
                </div>
            </div>
            <div class="home-fab-label">Macintosh HD</div>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public FileListViewModel ViewModel { get; set; } = null!;

    private async Task NavigateTo(string path)
    {
        await ViewModel.NavigateToCommand.ExecuteAsync(path);
    }
}
