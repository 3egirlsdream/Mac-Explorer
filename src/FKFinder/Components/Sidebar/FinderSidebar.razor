@using FKFinder.Models

<div class="finder-sidebar">
    <div class="sidebar-section">
        <div class="sidebar-section-title">收藏</div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><path d="M9 22V12h6v10"/></svg>
            <span class="sidebar-item-name">主目录</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory + "/Desktop" ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Desktop"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
            <span class="sidebar-item-name">桌面</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory + "/Documents" ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Documents"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="@Icons.FileText"/></svg>
            <span class="sidebar-item-name">文稿</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory + "/Downloads" ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Downloads"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            <span class="sidebar-item-name">下载</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory + "/Pictures" ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Pictures"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            <span class="sidebar-item-name">图片</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == ViewModel.HomeDirectory + "/Music" ? "active" : "")"
             @onclick="@(() => NavigateTo(ViewModel.HomeDirectory + "/Music"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
            <span class="sidebar-item-name">音乐</span>
        </div>
    </div>

    <div class="sidebar-section">
        <div class="sidebar-section-title">位置</div>
        <div class="sidebar-item @(ViewModel.CurrentPath == "/" ? "active" : "")"
             @onclick="@(() => NavigateTo("/"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="2.18"/><path d="M7 2v20M17 2v20M2 12h20M2 7h5M2 17h5M17 17h5M17 7h5"/></svg>
            <span class="sidebar-item-name">Macintosh HD</span>
        </div>
        <div class="sidebar-item @(ViewModel.CurrentPath == "/Applications" ? "active" : "")"
             @onclick="@(() => NavigateTo("/Applications"))">
            <svg class="sidebar-item-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
            <span class="sidebar-item-name">应用程序</span>
        </div>
    </div>
</div>

@code {
    [CascadingParameter] public FileListViewModel ViewModel { get; set; } = null!;

    private async Task NavigateTo(string path)
    {
        await ViewModel.NavigateToCommand.ExecuteAsync(path);
    }
}
