@using MacExplorer.Models
@using MacExplorer.Services
@inject IThumbnailService ThumbnailService
@inject IMetadataService MetadataService
@implements IDisposable

<div class="preview-pane panel-slide-in">
    <div class="preview-resize-handle"></div>
    @if (_selectedEntry != null)
    {
        <div class="preview-pane-header">
            <h3 title="@_selectedEntry.DisplayName">@_selectedEntry.DisplayName</h3>
            <div class="preview-subtitle">@_selectedEntry.FormattedSize — @_selectedEntry.LastModified.ToString("yyyy-MM-dd HH:mm")</div>
        </div>

        @if (!string.IsNullOrEmpty(_previewImageUrl))
        {
            <div class="preview-pane-image">
                <img src="@_previewImageUrl" alt="@_selectedEntry.DisplayName" />
            </div>
        }
        else
        {
            <div class="preview-pane-icon">
                @((MarkupString)GetLargeIcon(_selectedEntry))
            </div>
        }

        <div class="preview-pane-cards">
            @if (_selectedEntry != null && !_selectedEntry.IsDirectory)
            {
                <div class="preview-card">
                    <div class="preview-card-header">
                        <span class="preview-card-title">评级</span>
                    </div>
                    <div class="preview-card-body">
                        <div class="preview-pane-rating">
                            @for (int i = 1; i <= 5; i++)
                            {
                                var starIndex = i;
                                var isFilled = starIndex <= _currentRating;
                                <button class="star-btn @(isFilled ? "filled" : "")"
                                        @onclick="() => OnStarClick(starIndex)"
                                        title="@starIndex 星">
                                    <svg viewBox="0 0 24 24" fill="@(isFilled ? "currentColor" : "none")" stroke="currentColor" stroke-width="1.5">
                                        <path d="@Icons.StarOutline"/>
                                    </svg>
                                </button>
                            }
                        </div>
                    </div>
                </div>
            }

            @if (_imageMetadata != null)
            {
                var img = _imageMetadata;
                var hasExifInfo = !string.IsNullOrEmpty(img.CameraMake)
                    || !string.IsNullOrEmpty(img.CameraModel)
                    || !string.IsNullOrEmpty(img.LensModel)
                    || !string.IsNullOrEmpty(img.FocalLength)
                    || !string.IsNullOrEmpty(img.Aperture)
                    || !string.IsNullOrEmpty(img.ExposureTime)
                    || !string.IsNullOrEmpty(img.IsoSpeed)
                    || img.PixelWidth > 0;

                @if (hasExifInfo)
                {
                    <div class="preview-card">
                        <div class="preview-card-header preview-card-collapsible" @onclick="ToggleExifCard">
                            <span class="preview-card-title">基本信息</span>
                            <svg class="preview-card-toggle @(_exifCardExpanded ? "expanded" : "")" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                                <path d="@Icons.Forward"/>
                            </svg>
                        </div>
                        @if (_exifCardExpanded)
                        {
                            <div class="preview-card-body preview-card-body-scroll">
                                @if (img.PixelWidth > 0 && img.PixelHeight > 0)
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">尺寸</span>
                                        <span class="preview-info-value">@(img.PixelWidth) x @(img.PixelHeight)</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.ColorSpace))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">色彩空间</span>
                                        <span class="preview-info-value">@img.ColorSpace</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.CameraMake))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">制造商</span>
                                        <span class="preview-info-value">@img.CameraMake</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.CameraModel))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">相机型号</span>
                                        <span class="preview-info-value">@img.CameraModel</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.LensModel))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">镜头</span>
                                        <span class="preview-info-value">@img.LensModel</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.FocalLength))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">焦距</span>
                                        <span class="preview-info-value">@img.FocalLength</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.Aperture))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">光圈</span>
                                        <span class="preview-info-value">@img.Aperture</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.ExposureTime))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">快门速度</span>
                                        <span class="preview-info-value">@img.ExposureTime</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.IsoSpeed))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">ISO</span>
                                        <span class="preview-info-value">@img.IsoSpeed</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.WhiteBalance))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">白平衡</span>
                                        <span class="preview-info-value">@img.WhiteBalance</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.Flash))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">闪光灯</span>
                                        <span class="preview-info-value">@img.Flash</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.ExposureProgram))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">曝光程序</span>
                                        <span class="preview-info-value">@img.ExposureProgram</span>
                                    </div>
                                }
                                @if (!string.IsNullOrEmpty(img.MeteringMode))
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">测光模式</span>
                                        <span class="preview-info-value">@img.MeteringMode</span>
                                    </div>
                                }
                                @if (img.PhotoTakenDate.HasValue)
                                {
                                    <div class="preview-info-row">
                                        <span class="preview-info-label">拍摄时间</span>
                                        <span class="preview-info-value">@img.PhotoTakenDate.Value.ToString("yyyy-MM-dd HH:mm")</span>
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="preview-pane-empty">
            <span>选择文件以预览</span>
        </div>
    }
</div>

@code {
    [CascadingParameter] public FileListViewModel ViewModel { get; set; } = null!;

    private FileSystemEntry? _selectedEntry;
    private string? _previewImageUrl;
    private int _currentRating;
    private int _previewLoadGeneration;
    private bool _hasHighResPreview;
    private ImageMetadata? _imageMetadata;
    private bool _exifCardExpanded = true;
    private int _metadataLoadGeneration;

    protected override void OnInitialized()
    {
        ViewModel.PropertyChanged += OnViewModelPropertyChanged;
        ViewModel.SelectedEntries.CollectionChanged += OnSelectionChanged;
        UpdateSelection();
    }

    private async void OnViewModelPropertyChanged(object? sender, System.ComponentModel.PropertyChangedEventArgs e)
    {
        try
        {
            if (e.PropertyName == nameof(ViewModel.SelectedEntries))
            {
                ViewModel.SelectedEntries.CollectionChanged -= OnSelectionChanged;
                ViewModel.SelectedEntries.CollectionChanged += OnSelectionChanged;
                UpdateSelection();
                await InvokeAsync(StateHasChanged);
            }
            else if (e.PropertyName == nameof(ViewModel.Entries))
            {
                // Validate that the previewed file still exists in the new Entries
                if (_selectedEntry != null)
                {
                    var stillExists = ViewModel.Entries.Any(entry => entry.FullPath == _selectedEntry.FullPath);
                    if (!stillExists)
                    {
                        _previewLoadGeneration++;
                        _metadataLoadGeneration++;
                        _selectedEntry = null;
                        _previewImageUrl = null;
                        _currentRating = 0;
                        _hasHighResPreview = false;
                        _imageMetadata = null;
                        await InvokeAsync(StateHasChanged);
                        return;
                    }
                }

                // Thumbnails resolved asynchronously — refresh preview if the selected entry got a thumbnail
                // But don't downgrade if we already have a high-res preview
                if (_selectedEntry != null && !_hasHighResPreview && _previewImageUrl == null && !string.IsNullOrEmpty(_selectedEntry.ThumbnailUrl))
                {
                    _previewImageUrl = _selectedEntry.ThumbnailUrl;
                    await InvokeAsync(StateHasChanged);
                }
            }
        }
        catch (ObjectDisposedException) { }
        catch (Exception ex) { Console.WriteLine($"[PreviewPane] Property change callback failed: {ex}"); }
    }

    private async void OnSelectionChanged(object? sender, System.Collections.Specialized.NotifyCollectionChangedEventArgs e)
    {
        try
        {
            UpdateSelection();
            await InvokeAsync(StateHasChanged);
        }
        catch (ObjectDisposedException) { }
        catch (Exception ex) { Console.WriteLine($"[PreviewPane] Selection callback failed: {ex}"); }
    }

    private void UpdateSelection()
    {
        _previewLoadGeneration++;
        _metadataLoadGeneration++;
        _hasHighResPreview = false;
        _imageMetadata = null;
        if (ViewModel.SelectedEntries.Count == 1)
        {
            var entry = ViewModel.SelectedEntries[0];
            _selectedEntry = entry;
            _previewImageUrl = entry.ThumbnailUrl;
            _currentRating = ViewModel.GetRating(entry.FullPath);

            if (entry.IconKey == "file-image")
            {
                _ = LoadHighResPreviewAsync(entry);
                _ = LoadImageMetadataAsync(entry);
            }
        }
        else
        {
            _selectedEntry = null;
            _previewImageUrl = null;
            _currentRating = 0;
        }
    }

    private async Task LoadHighResPreviewAsync(FileSystemEntry entry)
    {
        var generation = _previewLoadGeneration;
        try
        {
            var bytes = await ThumbnailService.GetThumbnailAsync(entry.FullPath, 512);
            if (generation != _previewLoadGeneration || bytes == null) return;

            _previewImageUrl = $"data:image/png;base64,{Convert.ToBase64String(bytes)}";
            _hasHighResPreview = true;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private async Task LoadImageMetadataAsync(FileSystemEntry entry)
    {
        var generation = _metadataLoadGeneration;
        try
        {
            var metadata = await MetadataService.GetMetadataAsync(entry.FullPath);
            if (generation != _metadataLoadGeneration) return;

            _imageMetadata = metadata.ImageInfo;
            await InvokeAsync(StateHasChanged);
        }
        catch
        {
        }
    }

    private void ToggleExifCard()
    {
        _exifCardExpanded = !_exifCardExpanded;
    }

    private async Task OnStarClick(int rating)
    {
        if (_selectedEntry == null) return;
        var newRating = rating == _currentRating ? 0 : rating;
        _currentRating = newRating;
        await ViewModel.SetRatingAsync(_selectedEntry.FullPath, newRating);
    }

    private static string GetLargeIcon(FileSystemEntry entry)
    {
        if (entry.IsDirectory)
            return FileIconRenderer.RenderFolder(80);

        var ext = entry.Extension.TrimStart('.').ToUpperInvariant();
        return $@"<svg width=""80"" height=""80"" viewBox=""0 0 24 24"" fill=""none"">{Icons.File}</svg>
                  <div style=""margin-top:8px;font-size:13px;color:var(--color-text-tertiary);font-weight:500;"">.{ext}</div>";
    }

    private static string GetExtColor(string ext) => ext switch
    {
        "PDF" => "#E74C3C",
        "DOC" or "DOCX" => "#2B579A",
        "XLS" or "XLSX" => "#217346",
        "PPT" or "PPTX" => "#D24726",
        "ZIP" or "RAR" or "7Z" or "TAR" or "GZ" => "#F39C12",
        "MP3" or "WAV" or "FLAC" or "AAC" => "#8E44AD",
        "MP4" or "AVI" or "MKV" or "MOV" => "#E91E63",
        "JS" or "TS" or "JSX" or "TSX" => "#F0DB4F",
        "PY" => "#3776AB",
        "CS" => "#68217A",
        "JAVA" => "#B07219",
        "GO" => "#00ADD8",
        "RS" => "#DEA584",
        "HTML" or "HTM" => "#E34F26",
        "CSS" or "SCSS" => "#1572B6",
        "JSON" or "YAML" or "YML" or "XML" => "#A0A0A0",
        _ => "#8E8E93"
    };

    public void Dispose()
    {
        ViewModel.PropertyChanged -= OnViewModelPropertyChanged;
        ViewModel.SelectedEntries.CollectionChanged -= OnSelectionChanged;
    }
}
