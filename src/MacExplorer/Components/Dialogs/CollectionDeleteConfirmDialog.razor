@using MacExplorer.Models

<div class="delete-confirm-dialog">
    <div class="delete-confirm-title">确认删除收藏夹</div>
    <div class="delete-confirm-message">
        <span>确定要删除收藏夹 "@CollectionName" 吗？收藏夹中的文件不会被删除。</span>
    </div>
    <div class="delete-confirm-actions">
        <button class="modal-btn modal-btn-cancel" @onclick="Cancel">取消</button>
        <button class="modal-btn modal-btn-danger" @onclick="Confirm">删除</button>
    </div>
</div>

@code {
    [Parameter] public string CollectionName { get; set; } = "";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
